class CallbackInfo:
    """Snapshot of optimizer state passed to callbacks."""

    iteration: int
    cost: float
    gradient_norm: Optional[float]
    elapsed_seconds: float
    converged: bool
    step_size: Optional[float]
    line_search_iterations: Optional[int]
    trust_region_radius: Optional[float]
    step_accepted: Optional[bool]
    relative_improvement: Optional[float]
    extra_info: Optional[Any]
    @property
    def point(self) -> Optional[NDArray[np.float64]]: ...
    @property
    def gradient(self) -> Optional[NDArray[np.float64]]: ...
    @property
    def search_direction(self) -> Optional[NDArray[np.float64]]: ...

class OptimizationCallback:
    """Base class for callbacks; subclass in Python."""

    def __init__(self) -> None: ...
    def on_optimization_start(self) -> None: ...
    def on_iteration_end(self, info: CallbackInfo) -> bool:
        """Return ``False`` to request early termination."""
        ...
    def on_optimization_end(self, info: CallbackInfo) -> None: ...

class CallbackManager:
    """Manage a collection of callbacks."""

    def __init__(self, callbacks: Optional[List[Any]] = ...) -> None: ...
    def add_callback(self, callback: Any) -> None: ...
    def remove_callback(self, callback: Any) -> bool: ...
    def clear(self) -> None: ...
    def enable(self) -> None: ...
    def disable(self) -> None: ...
    @property
    def enabled(self) -> bool: ...
    @property
    def num_callbacks(self) -> int: ...

