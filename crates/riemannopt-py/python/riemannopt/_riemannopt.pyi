# ---------------------------------------------------------------------------
# Cost function
# ---------------------------------------------------------------------------

class CostFunction:
    """Wrapper around a Python cost function for use by Rust optimizers.

    Prefer :func:`create_cost_function` to construct instances.
    """

    def __init__(
        self,
        cost_fn: Callable[[NDArray[np.float64]], float],
        grad_fn: Optional[Callable[[NDArray[np.float64]], NDArray[np.float64]]] = ...,
        cost_and_grad_fn: Optional[
            Callable[[NDArray[np.float64]], Tuple[float, NDArray[np.float64]]]
        ] = ...,
        dimension: Optional[Union[int, Tuple[int, int]]] = ...,
    ) -> None: ...
    def cost(self, point: ArrayLike) -> float:
        """Evaluate the cost at *point*."""
        ...
    def gradient(self, point: ArrayLike) -> NDArray[np.float64]:
        """Evaluate the Euclidean gradient at *point*."""
        ...
    def cost_and_gradient(
        self, point: ArrayLike
    ) -> Tuple[float, NDArray[np.float64]]:
        """Return ``(cost, gradient)`` at *point*."""
        ...
    def reset_counts(self) -> None:
        """Reset evaluation counters to zero."""
        ...
    @property
    def eval_counts(self) -> Dict[str, int]:
        """Number of cost / gradient / cost_and_gradient evaluations."""
        ...

def create_cost_function(
    cost: Callable[..., Any],
    gradient: Optional[Callable[..., Any]] = ...,
    cost_and_gradient: Optional[Callable[..., Any]] = ...,
    dimension: Optional[Union[int, Tuple[int, int]]] = ...,
    validate: bool = ...,
    auto_detect: bool = ...,
) -> CostFunction:
    """Factory that wraps a Python callable into a :class:`CostFunction`.

    When *gradient* is omitted and *cost* does not return a ``(cost, grad)``
    tuple, finite differences are used automatically.
    """
    ...

